# ============================================================
# Node.js / npm
# ============================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnp/
.pnp.js
package-lock.json.bak
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz

# ============================================================
# Build artifacts
# ============================================================
dist/
build/
out/
*.tsbuildinfo

# Vite cache
.vite/
.vite-temp/

# Next.js, Nuxt, etc. (no incluidos, pero por seguridad)
.next/
.nuxt/

# ============================================================
# Environment & secrets
# ============================================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local
!.env.example

# ============================================================
# Bases de datos (generadas en runtime)
# ============================================================
*.db
*.db-journal
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# ============================================================
# Logs
# ============================================================
logs/
*.log

# ============================================================
# OS / Editor
# ============================================================
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example
*.swp
*.swo
*~

# ============================================================
# Cobertura de tests
# ============================================================
coverage/
.nyc_output/
*.lcov

# ============================================================
# Cache y temporales
# ============================================================
.cache/
.parcel-cache/
.tmp/
temp/

# ============================================================
# Documentos de Office (tareas .docx van en /tareas pero los backups no)
# ============================================================
~$*.docx
~$*.xlsx
~$*.pptx

# ============================================================
# Uploads de usuario (si los hubiera)
# ============================================================
uploads/
public/uploads/

# ============================================================
# Documentación académica local (se entrega por la plataforma UAPA,
# no forma parte del repositorio de código)
# ============================================================
tareas/

# ============================================================
# Screenshots placeholder (los reales los pones tú en /docs/screenshots/)
# ============================================================
docs/screenshots/*.tmp