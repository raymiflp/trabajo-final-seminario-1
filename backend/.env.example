# ============================================================
# Variables de entorno del BACKEND (ejemplo)
# Copia este archivo a backend/.env y completa los valores.
# ============================================================

# Puerto del servidor Express
PORT=3000

# Secreto para firmar los JWT — genera uno aleatorio largo en producción
# Puedes usar: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambia-esto-por-una-cadena-aleatoria-larga-en-produccion

# URL pública del frontend (para construir los QR)
# En desarrollo: http://localhost:5174
# En producción: https://tu-dominio.com
FRONTEND_URL=http://localhost:5174

# Entorno
NODE_ENV=development